    <selectionEntry id="531f-c708-1afb-af70" name="Comehombres de Golgfag (Todos menos Bretonia, Reinos Ogros y Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="7509-b4cc-31df-1544" type="max"/>
      </constraints>
      <rules>
        <rule id="6b1f-1aab-4b77-5779" name="Inclusión" hidden="false">
          <description>Puedes incluir los Ogros de Golgfag como una unidad Especial en un ejército de Mercenarios o de Reinos Ogros. También puedes incluir los Ogros de Golgfag como una unidad Singular en cualquier otro ejército, salvo Bretonia.
</description>
        </rule>
