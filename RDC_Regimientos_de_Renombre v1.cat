    <selectionEntry id="392d-7ce7-a3b3-7df7" name="Hombres pájaro de Catrazza (Imperio, Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="36ed-6fb3-b87d-9579" type="max"/>
      </constraints>
      <rules>
        <rule id="8b4d-082f-aed3-c528" name="Inclusión" hidden="false">
          <description>Puedes incluir a los Hombres Pájaro de Catrazza en tu ejército Mercenario o en un ejército del Imperio como unidad Singular.</description>
        </rule>
        <rule id="4d9e-48f1-2f9a-7a86" name="Disparar en vuelo" hidden="false">
          <description>Los Hombres Pájaro no tienen el penalizador de -1 a sus tiradas para impactar a distancia por mover y disparar a menos que utilicen su movimiento terrestre.</description>
        </rule>
