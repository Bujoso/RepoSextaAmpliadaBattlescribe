              </constraints>
              <selectionEntries>
                <selectionEntry id="8f0d-8938-aac5-2de7" name="Hacha Rúnica de Gotrek" hidden="false" collective="true" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="d1e0-fce1-903c-12bb" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="ef5b-7744-9aff-0bc4" type="min"/>
                  </constraints>
                  <rules>
                    <rule id="f30b-2eee-3fee-7e1b" name="Hacha Rúnica de Gotrek" hidden="false">
                      <description>Arma de mano. Por cada ataque inicial que impacte, Gotrek puede hacer un ataque adicional. (Los ataques adicionales que impacten no generan ataques adicionales). Todos sus ataques Anulan Armadura. Heridas múltiples (2) contra miniaturas de R5 o superior.</description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="puntos" typeId="53ea-00f4-9046-81ff" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
          </selectionEntryGroups>
          <costs>
            <cost name="puntos" typeId="53ea-00f4-9046-81ff" value="313.0"/>
          </costs>
        </selectionEntry>
      </selectionEntries>
