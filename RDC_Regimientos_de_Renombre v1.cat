      <rules>
        <rule id="76da-5be1-feb1-eb1d" name="Inclusión" hidden="false">
          <description>Puedes incluir a los Tiradores de Miragliano en tu ejército Mercenario como una opción de unidad Básica, o en cualquier otro ejército de Warhammer (salvo Bretonia y Skaven) como unidad Singular.</description>
        </rule>
