    <selectionEntry id="d97b-83f2-002b-40fb" name="Incursores de Tichi Huichi (Hombres Lagarto)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="cf44-74f8-da59-3f5a" type="max"/>
      </constraints>
      <profiles>
        <profile id="b346-86b2-a75e-dd12" name="Gélido de Gran Cresta" hidden="false" typeId="1025-8460-b30f-58db" typeName="Modelo">
          <characteristics>
            <characteristic name="M" typeId="2d56-9cad-9242-37bd">20</characteristic>
            <characteristic name="HA" typeId="c87b-b820-6a47-1354">3</characteristic>
            <characteristic name="HP" typeId="8ab7-c800-6644-f5ec"/>
            <characteristic name="F" typeId="79c2-0368-3eed-76b4">4</characteristic>
            <characteristic name="R" typeId="30bd-8385-2b51-e039"/>
            <characteristic name="H" typeId="a41f-60f6-2336-73ab"/>
            <characteristic name="I" typeId="fdd9-0cd1-90d5-1b6f">1</characteristic>
            <characteristic name="A" typeId="6b2b-37c4-6774-748b">2</characteristic>
            <characteristic name="L" typeId="458e-bb4b-f7c9-e0b3">3</characteristic>
            <characteristic name="TSA" typeId="2532-2940-06ec-7a6e">+2</characteristic>
            <characteristic name="Tipo" typeId="4a99-e6a0-4022-a833">Caballería</characteristic>
            <characteristic name="Potencia" typeId="6bbb-9823-b0cd-5705">2 (1+1 del jinete)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="41ad-9a6f-8831-8e50" name="Inclusión" hidden="false">
          <description>Puedes incluir a los Incursores de Tichi Huichi en un ejército de Hombres Lagarto como una opción de unidad Especial.
Puedes incluir a los Incursores de Tichi Huichi en cualquier otro ejército (excepto Bretonia, Caos, Condes Vampiro, Enanos del Caos, Reyes Funerarios y Skavens) como unidad Singular.</description>
        </rule>
        <rule id="43a6-0eec-dd21-7b4d" name="Pellejo duro" hidden="false">
          <description>Los Gélidos de Gran Cresta proporcionan un +2 a la tirada de salvación por armadura del jinete en vez de +1.</description>
        </rule>
        <rule id="bb5f-47b2-3306-364a" name="Bendecidos por los Ancestrales" hidden="false">
          <description>Si los Incursores de Tichi Huichi huyen de un combate (por ejemplo, a causa del miedo, o de un chequeo de desmoralización), los enemigos siempre deben mantener la posición (no pueden perseguir, incluso aunque tengan una regla que obligue a perseguir).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="9051-3383-8458-f484" name="Regimientos de Renombre" hidden="false" targetId="2731-433c-1379-1c3c" type="rule"/>
