      <rules>
        <rule id="d565-b523-28e0-e4a9" name="Inclusión" hidden="false">
          <description>Puedes incluir los Ogros de Golgfag como una unidad Especial en un ejército de Mercenarios o de Reinos Ogros. También puedes incluir los Ogros de Golgfag como una unidad Singular en cualquier otro ejército, salvo Bretonia.
</description>
        </rule>
