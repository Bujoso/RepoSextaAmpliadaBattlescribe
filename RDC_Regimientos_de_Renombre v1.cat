    <selectionEntry id="a9cd-8740-60aa-ebe3" name="Matadores Pirata de Drong el Largo (Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="8057-dc42-f969-4d5c" type="max"/>
      </constraints>
      <rules>
        <rule id="7893-83dd-2f42-c697" name="Inclusión" hidden="false">
          <description>Puedes incluir a los Matadores Piratas de Drong el Largo en tu ejército Mercenario como una opción de unidad Especial.
Puedes incluir a los Matadores Piratas de Drong el Largo en cualquier otro ejército de Warhammer (salvo Bretonia, Altos Elfos,  Elfos Silvanos, Orcos y Goblins y Enanos del Caos) como unidad Singular.</description>
        </rule>
      </rules>
