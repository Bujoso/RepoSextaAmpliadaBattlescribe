            <characteristic name="Tipo" typeId="4a99-e6a0-4022-a833">Infantería, Humano, Hechicero.</characteristic>
            <characteristic name="Potencia" typeId="6bbb-9823-b0cd-5705">1</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="b5df-a7e7-38e6-a901" name="Inclusión" hidden="false">
          <description>Puedes incluir la Sacerdotisa Serpiente como una opción de Héroe más una opción de unidad Singular en un ejército de Hombres Lagarto, Altos Elfos, Elfos Silvanos, Enanos, Imperio, Mercenarios o Reinos Ogros (si no incluyes un contingente aliado de Amazonas).</description>
        </rule>
        <rule id="5a9e-d630-00f8-74ac" name="Personaje" hidden="false">
          <description>Pese a ser un Regimiento de Renombre a la hora de hacer la lista de ejército, la Sacerdotisa Serpiente se considera un Personaje a todos los demás efectos, y puede unirse a unidades, éstas pueden usar su Liderazgo, etc. La Sacerdotisa Serpiente no puede ser el General del ejército.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="1b94-1f37-8432-e7e7" name="Regimientos de Renombre" hidden="false" targetId="2731-433c-1379-1c3c" type="rule"/>
      </infoLinks>
