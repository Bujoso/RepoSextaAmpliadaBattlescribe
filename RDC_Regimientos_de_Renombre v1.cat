                  </constraints>
                  <rules>
                    <rule id="c674-56bc-d800-ee5b" name="Jarra de cerveza de Bugman" hidden="false">
                      <description>En cada fase de movimiento, si la unidad no está trabada, todo personaje de la unidad (tanto Bugman
como cualquier personaje que se haya unido) beben de la cerveza y recuperan una herida (hasta su máximo inicial). </description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="puntos" typeId="53ea-00f4-9046-81ff" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
            </selectionEntryGroup>
