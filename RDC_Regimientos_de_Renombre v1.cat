                    <profile id="e158-1e51-a3f2-d002" name="Garra de los ancestrales (disparo)" hidden="false" typeId="83dc-30c1-3c91-3ea4" typeName="Arma">
                      <characteristics>
                        <characteristic name="Alcance" typeId="cafc-207a-b76d-8124">30</characteristic>
                        <characteristic name="Fuerza" typeId="c938-3c85-689c-fbbd">3</characteristic>
                        <characteristic name="Reglas especiales" typeId="4348-8db0-9b33-fd91">Se trata de un ataque de proyectiles con alcance 30cm y causa impactos flamígeros de F3. Ignora las penalizaciones por largo alcance o por mover y disparar. No son un arma mágica (no le afecta la Anulación de Vaul, ni puede herir a criaturas etéreas).</characteristic>
                      </characteristics>
                    </profile>
                  </profiles>
                  <costs>
                    <cost name="puntos" typeId="53ea-00f4-9046-81ff" value="0.0"/>
                  </costs>
                </selectionEntry>
              </selectionEntries>
