            <characteristic name="L" typeId="458e-bb4b-f7c9-e0b3">3</characteristic>
            <characteristic name="TSA" typeId="2532-2940-06ec-7a6e">+1</characteristic>
            <characteristic name="Tipo" typeId="4a99-e6a0-4022-a833">Caballería</characteristic>
            <characteristic name="Potencia" typeId="6bbb-9823-b0cd-5705">2 (1+1 del jinete)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="2e63-0eb6-7189-bdbe" name="Inclusión" hidden="false">
          <description>Puedes incluir a los Jinetez de Oglah Khan en tu ejército Mercenario o en uno de Enanos del Caos como una opción de unidad Especial.
Puedes incluir a los Jinetez de Oglah Khan en cualquier otro ejército de Warhammer (salvo Bretonia, Altos Elfos, Elfos Silvanos, Imperio y Enanos) como unidad Singular.</description>
        </rule>
        <rule id="9b64-147b-b0ac-37f9" name="Desprecio" hidden="false">
          <description>Los Hobgoblins que huyen no causan pánico en otros Pielesverdes, pero sí a otros Hobgoblins.</description>
        </rule>
      </rules>
