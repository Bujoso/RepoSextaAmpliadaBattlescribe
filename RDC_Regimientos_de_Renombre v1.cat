    <selectionEntry id="5cbc-7fe9-fa57-dd4c" name="Gotrek y Félix (Enanos, Bretonia, Imperio, Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="3e45-b862-3185-fdf4" type="max"/>
      </constraints>
      <rules>
        <rule id="176d-0b07-bbfa-9bf0" name="Inclusión" hidden="false">
          <description>Puedes incluir a Gotrek y Félix como una unidad Singular en un ejército de Enanos, Bretonia, Mercenarios o El Imperio.</description>
        </rule>
        <rule id="ec4a-0c5d-22d3-e335" name="Maldición de Gotrek" hidden="false">
          <description>Mientras Gotrek siga vivo, Gotrek y Félix tienen una tirada de salvación especial de 4+ y Resistencia a la magia (2) (en total, no RM2 cada uno). Gotrek nunca podrá unirse nunca a ninguna unidad. Mientras Gotrek siga vivo, Félix no podrá unirse a ninguna unidad (ambos forman una unidad de Hostigadores). Mientras Gotrek siga vivo, son Inmunes a desmoralización.</description>
        </rule>
        <rule id="2370-5966-5851-1b6a" name="Formación" hidden="false">
          <description>Ten en cuenta que ambos forman una unidad independiente formada por dos miniaturas a todos los efectos, no son dos personajes sueltos</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="4981-f58b-5e04-253f" name="Regimientos de Renombre" hidden="false" targetId="2731-433c-1379-1c3c" type="rule"/>
        <infoLink id="8b2a-cd29-1ce0-b819" name="Hostigadores" hidden="false" targetId="4717-34b5-7e01-9c40" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="3b10-12e1-6565-faf6" name="New CategoryLink" hidden="false" targetId="184a-30ec-bf7c-b603" primary="true"/>
      </categoryLinks>
