    <selectionEntry id="0b02-04e2-41d6-40c3" name="Sacerdotisa serpiente (Ocupa héroe y singular)(Altos Elfos, Elfos Silvanos, Enanos, Hombres Lagarto, Imperio, Mercenarios, Reinos Ogros)" hidden="false" collective="false" import="true" type="model">
      <constraints>
