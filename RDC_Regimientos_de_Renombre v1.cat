    <selectionEntry id="3f96-9976-9a87-f41e" name="Arqueros de Scarloc (Altos Elfos, Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="55fc-9636-4424-aa28" type="max"/>
      </constraints>
      <rules>
        <rule id="4ca4-ef93-039c-7065" name="Arquería de los Asrai" hidden="false">
          <description>Los Arqueros (incluyendo a Scarloc, Kaya y Glam) son Elfos Silvanos, así que no sufren la penalización de -1 en la tirada para impactar por mover y disparar.</description>
        </rule>
        <rule id="91a2-8bdd-fe80-6b2b" name="Inclusión" hidden="false">
          <description>La unidad puede incluirse como unidad especial en un ejército de Elfos Silvanos, o como unidad singular en un ejército Mercenario o de Altos Elfos.</description>
        </rule>
      </rules>
