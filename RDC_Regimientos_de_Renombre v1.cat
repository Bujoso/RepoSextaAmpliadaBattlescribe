                <characteristic name="H" typeId="a41f-60f6-2336-73ab">3</characteristic>
                <characteristic name="I" typeId="fdd9-0cd1-90d5-1b6f">5</characteristic>
                <characteristic name="A" typeId="6b2b-37c4-6774-748b">4</characteristic>
                <characteristic name="L" typeId="458e-bb4b-f7c9-e0b3">10</characteristic>
                <characteristic name="TSA" typeId="2532-2940-06ec-7a6e"/>
                <characteristic name="Tipo" typeId="4a99-e6a0-4022-a833">Infantería, Enano, Matador</characteristic>
                <characteristic name="Potencia" typeId="6bbb-9823-b0cd-5705">1</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <rules>
            <rule id="603a-5380-93ba-213a" name="Matador" hidden="false">
              <description>Cuando una miniatura con esta regla impacte a un enemigo con un atributo de Resistencia superior a la Fuerza del ataque (Fuerza modificada por runas, arma a dos manos, etc), puede resolver ese impacto como si tuviera una Fuerza (modificada) igual a la Resistencia del enemigo impactado (en el caso de Gotrek esto no está limitado hasta un máximo de 6). Por ejemplo, si impacta a un enemigo con R5, se considerará que tiene F5 a todos los efectos (hiere a 4+, tiene un -2 a la tirada de salvación por armadura).</description>
            </rule>
            <rule id="a569-e0ea-a54d-9b90" name="Inmune a desmoralización (aunque sigue teniendo Odio a pielesverdes)" hidden="false"/>
          </rules>
          <infoLinks>
            <infoLink id="5d1c-299f-c199-5606" name="Agravio ancestral" hidden="false" targetId="a608-9816-3807-6b5e" type="rule"/>
            <infoLink id="5851-3ad0-616f-0023" name="Avance imparable" hidden="false" targetId="0ca0-0884-aff8-cf67" type="rule"/>
            <infoLink id="169a-4119-2483-ef6d" name="Firmeza" hidden="false" targetId="6b38-c278-625d-d064" type="rule"/>
          </infoLinks>
          <selectionEntryGroups>
            <selectionEntryGroup id="68a8-431f-2d3f-c2d8" name="Armas" hidden="false" collective="false" import="true" defaultSelectionEntryId="8f0d-8938-aac5-2de7">
