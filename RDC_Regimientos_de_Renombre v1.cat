    <selectionEntry id="eb94-04ce-2cc1-1830" name="Gigantes de Albión (Ocupan dos huecos de singular)(Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="404a-0e16-2744-88ff" type="max"/>
      </constraints>
      <rules>
        <rule id="885d-6503-a2be-d1e3" name="Inclusión" hidden="false">
          <description>Puedes incluir los Gigantes de Albión en un ejército Mercenario pero ocupa las dos opciones de unidad Singular. NO puedes incluir los Gigantes de Albión en un ejército que no sea Mercenario (son un Regimiento de Renombre único para los Mercenarios).</description>
        </rule>
        <rule id="e057-b6db-66e9-9940" name="Miniaturas individuales" hidden="false">
          <description>Hengus, Cachtorr y Pelotos son miniaturas independientes y, por tanto, se mueven de forma individual,
aunque no pueden unirse a otros regimientos.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="8867-b39b-0465-b9e0" name="Regimientos de Renombre" hidden="false" targetId="2731-433c-1379-1c3c" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="4369-89f0-c1d3-2ae6" name="New CategoryLink" hidden="false" targetId="184a-30ec-bf7c-b603" primary="true"/>
      </categoryLinks>
