              <selectionEntries>
                <selectionEntry id="c03e-8a1c-d4ab-e8a1" name="Estaca de Sigmar" hidden="false" collective="true" import="true" type="upgrade">
                  <constraints>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e33c-182b-3208-34aa" type="max"/>
                    <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="bff5-903a-e886-c58d" type="min"/>
                  </constraints>
                  <rules>
                    <rule id="0e60-19a4-893a-a3a8" name="Estaca de Sigmar" hidden="false">
                      <description>Requiere ambas manos. Duplica la Fuerza de Johann cuando lucha contra miniaturas de tipo No Muerto o Demonio (esto en principio supone F8). Además, una única herida no salvada causada por este arma causa la muerte instantánea de cualquier Vampiro, que tampoco puede Regenerar esas heridas. Está obligado a utilizar este arma en vez de las dos pistolas si está en contacto con algún No Muerto o Demonio. </description>
                    </rule>
                  </rules>
                  <costs>
                    <cost name="puntos" typeId="53ea-00f4-9046-81ff" value="0.0"/>
                  </costs>
                </selectionEntry>
                <selectionEntry id="edb3-51f5-6c85-9d2b" name="Par de pistolas" hidden="false" collective="true" import="true" type="upgrade">
