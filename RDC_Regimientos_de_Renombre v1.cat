                <characteristic name="HA" typeId="c87b-b820-6a47-1354">7</characteristic>
                <characteristic name="HP" typeId="8ab7-c800-6644-f5ec">2</characteristic>
                <characteristic name="F" typeId="79c2-0368-3eed-76b4">4</characteristic>
