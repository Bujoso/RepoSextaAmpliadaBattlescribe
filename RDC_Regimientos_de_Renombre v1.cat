    <selectionEntry id="2e52-347f-ffbb-db6d" name="Asarnil, señor de los dragones(Ocupa héroe y singular)(Sólo a 2.000 puntos o más)(Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="74d0-17de-58fd-7660" type="max"/>
      </constraints>
      <rules>
        <rule id="0cc3-9cb0-2693-58f2" name="Inclusión" hidden="false">
          <description>Puedes incluir a Asarnil, Señor de los Dragones en tu ejército Mercenario como una opción de Héroe más una de unidad Singular.
También puedes incluirlo, pero ocupando dos opciones de Héroe y una de unidad Singular, en un ejército de Altos Elfos, Elfos Silvanos, Imperio u Hombres Lagarto.
Ten en cuenta que ni Asarnil ni Colmillo de Muerte son un personaje (aunque tengan nombre y sean 0-1), así que no puede ser el General, ni puede unirse a unidades (en caso de que Colmillo de Muerte muera, Asarnil será una miniatura de infantería correteando para salvar su pellejo).
Sólo se puede incluir en partidas a 2.000 puntos o más.</description>
        </rule>
        <rule id="4704-02e0-7685-40d6" name="Coste" hidden="false">
          <description>460 puntos (130 por Asarnil, 330 por Colmillo de Muerte). En este caso se proporcionan puntos de victoria independientes por Asarnil y por Colmillo de Muerte, siguiendo las reglas habituales de puntos de victoria para personajes.</description>
        </rule>
        <rule id="49c5-c25b-371b-911a" name="Líder" hidden="false">
          <description>Asarnil es el Líder del regimiento de renombre (aunque siga algunas reglas de personajes, sigue sin ser un personaje; por ejemplo, si muere Colmillo de Muerte no puede unirse a otras unidades).</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="c4f4-6507-9233-669b" name="Regimientos de Renombre" hidden="false" targetId="2731-433c-1379-1c3c" type="rule"/>
      </infoLinks>
      <categoryLinks>
        <categoryLink id="4bbb-6f26-dd48-367d" name="New CategoryLink" hidden="false" targetId="184a-30ec-bf7c-b603" primary="true"/>
        <categoryLink id="7934-a75e-9edb-aa21" name="Héroe" hidden="false" targetId="c647-4209-4e6c-206a" primary="false"/>
      </categoryLinks>
      <selectionEntries>
        <selectionEntry id="57ac-5200-f0f3-c63d" name="Colmillo de Muerte" hidden="false" collective="false" import="true" type="upgrade">
          <constraints>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="213e-3dd2-962f-a217" type="min"/>
            <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="6504-20a3-e248-4a41" type="max"/>
          </constraints>
          <profiles>
            <profile id="f86e-aeae-ad36-a342" name="Colmillo de Muerte" hidden="false" typeId="1025-8460-b30f-58db" typeName="Modelo">
              <characteristics>
                <characteristic name="M" typeId="2d56-9cad-9242-37bd">15</characteristic>
                <characteristic name="HA" typeId="c87b-b820-6a47-1354">6</characteristic>
                <characteristic name="HP" typeId="8ab7-c800-6644-f5ec">0</characteristic>
                <characteristic name="F" typeId="79c2-0368-3eed-76b4">6</characteristic>
                <characteristic name="R" typeId="30bd-8385-2b51-e039">6</characteristic>
                <characteristic name="H" typeId="a41f-60f6-2336-73ab">6</characteristic>
                <characteristic name="I" typeId="fdd9-0cd1-90d5-1b6f">3</characteristic>
                <characteristic name="A" typeId="6b2b-37c4-6774-748b">5</characteristic>
                <characteristic name="L" typeId="458e-bb4b-f7c9-e0b3">8</characteristic>
                <characteristic name="TSA" typeId="2532-2940-06ec-7a6e">3+</characteristic>
