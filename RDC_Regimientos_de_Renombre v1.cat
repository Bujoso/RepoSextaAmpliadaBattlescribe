    <selectionEntry id="c408-c29a-2ebe-52c2" name="Montaraces de Bugman (Mercenarios)" hidden="false" collective="false" import="true" type="unit">
      <constraints>
        <constraint field="selections" scope="parent" value="1.0" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b7d7-2bd4-f90e-5bee" type="max"/>
      </constraints>
      <rules>
        <rule id="22b6-ba35-8e53-ddf3" name="Inclusión" hidden="false">
          <description>Puedes incluir a los Montaraces de Bugman como una opción de unidad Especial en un ejército de Mercenarios, o como una unidad Singular en un ejército del Imperio o Reinos Ogros. (Los Enanos tienen a Josef Bugman como personaje especial).</description>
        </rule>
        <rule id="fc1c-9acd-9fe3-2cfc" name="Montaraces de Bugman (Mercenarios)" hidden="false">
          <description>Mientras Bugman siga vivo, Bugman y la unidad son Inmunes a miedo e Inmunes a terror.</description>
        </rule>
      </rules>
      <infoLinks>
